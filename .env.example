# Copy this file to .env and fill in your actual credentials.
# DO NOT commit .env — it is git-ignored.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- LLM provider used by the Agent (openai | google | anthropic) ---
LLM_PROVIDER=openai

# --- Agent generation model ---
AGENT_MODEL=gpt-4o-mini

# --- Multi-Judge configuration ---
# Two different OpenAI models act as independent Judges so we can
# compute agreement-rate / Cohen's Kappa and detect single-judge bias.
# IMPORTANT: both Judges MUST differ from the SDG model (gpt-4o-mini)
# to avoid self-preference bias — the Judge favors answers that look
# like what it would have written, which inflates scores for agents
# that share its training distribution.
JUDGE_MODEL_A=gpt-4o
JUDGE_MODEL_B=gpt-4-turbo

# --- Embedding model for ChromaDB retrieval ---
EMBEDDING_MODEL=text-embedding-3-small
